generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  display_name       String
  avatar_url         String?
  xp_total           Int       @default(0)
  level              Int       @default(1)
  streak_count       Int       @default(0)
  longest_streak     Int       @default(0)
  last_activity_date DateTime? @db.Date
  timezone           String    @default("UTC")
  learning_goal      String?
  created_at         DateTime  @default(now()) @db.Timestamptz()
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz()

  topics         Topic[]
  review_cards   ReviewCard[]
  review_sessions ReviewSession[]
  review_results ReviewResult[]
  achievements   Achievement[]
  notifications  Notification[]
  topic_schedules TopicReviewSchedule[]

  @@map("users")
}

model Topic {
  id            String   @id @default(uuid())
  user_id       String
  title         String
  description   String?
  raw_notes     String?
  status        String   @default("active")
  card_count    Int      @default(0)
  mastery_score Float    @default(0.0)
  color         String   @default("#6C47FF")
  emoji         String   @default("📚")
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz()

  user          User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  review_cards  ReviewCard[]
  review_sessions ReviewSession[]
  review_schedules TopicReviewSchedule[]

  @@index([user_id, status])
  @@index([user_id, created_at(sort: Desc)])
  @@map("topics")
}

model ReviewCard {
  id              String    @id @default(uuid())
  topic_id        String
  user_id         String
  front           String
  back            String
  card_type       String    @default("basic")
  mcq_options     Json?
  hint            String?
  tags            String[]  @default([])
  ai_generated    Boolean   @default(true)
  // SM-2 fields
  ease_factor     Float     @default(2.5)
  interval_days   Int       @default(1)
  repetitions     Int       @default(0)
  next_review_at  DateTime  @default(now()) @db.Timestamptz()
  last_reviewed_at DateTime? @db.Timestamptz()
  // Stats
  times_correct   Int       @default(0)
  times_incorrect Int       @default(0)
  created_at      DateTime  @default(now()) @db.Timestamptz()

  topic          Topic          @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  review_results ReviewResult[]

  @@index([user_id, next_review_at])
  @@index([topic_id])
  @@map("review_cards")
}

model ReviewSession {
  id             String    @id @default(uuid())
  user_id        String
  topic_id       String?
  session_type   String    @default("scheduled")
  started_at     DateTime  @default(now()) @db.Timestamptz()
  completed_at   DateTime? @db.Timestamptz()
  cards_reviewed Int       @default(0)
  cards_correct  Int       @default(0)
  xp_earned      Int       @default(0)
  duration_secs  Int?

  user           User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  topic          Topic?         @relation(fields: [topic_id], references: [id])
  review_results ReviewResult[]

  @@map("review_sessions")
}

model ReviewResult {
  id              String   @id @default(uuid())
  session_id      String
  card_id         String
  user_id         String
  rating          Int
  response_time_ms Int?
  new_interval    Int
  new_ease_factor Float
  reviewed_at     DateTime @default(now()) @db.Timestamptz()

  session  ReviewSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  card     ReviewCard    @relation(fields: [card_id], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, reviewed_at(sort: Desc)])
  @@index([card_id, reviewed_at(sort: Desc)])
  @@map("review_results")
}

model Achievement {
  id        String   @id @default(uuid())
  user_id   String
  badge_id  String
  earned_at DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, badge_id])
  @@map("achievements")
}

model Notification {
  id         String    @id @default(uuid())
  user_id    String
  type       String
  title      String
  body       String
  read       Boolean   @default(false)
  sent_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model TopicReviewSchedule {
  id           String   @id @default(uuid())
  topic_id     String
  user_id      String
  interval_num Int      // e.g., 1, 3, 7, 14, 30
  review_date  DateTime @db.Date
  status       String   @default("pending") // pending, completed, missed
  created_at   DateTime @default(now()) @db.Timestamptz()

  topic        Topic    @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, review_date])
  @@index([topic_id])
  @@map("topic_review_schedules")
}
